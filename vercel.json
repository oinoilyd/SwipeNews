{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "crons": [
    { "path": "/api/pregenerate", "schedule": "0 6 * * *" },
    { "path": "/api/refresh-rss", "schedule": "0 6 * * *" },
    { "path": "/api/pregenerate?topicsOnly=1", "schedule": "0 0,12,18 * * *" }
  ],
  "functions": {
    "api/clustered-news.js": { "maxDuration": 10  },
    "api/pregenerate.js":    { "maxDuration": 60  },
    "api/refresh-rss.js":    { "maxDuration": 30  },
    "api/generate-takes.js": { "maxDuration": 30  },
    "api/stream-take.js":    { "maxDuration": 30  },
    "api/votes.js":          { "maxDuration": 10  },
    "api/trending.js":       { "maxDuration": 10  },
    "api/keep-warm.js":      { "maxDuration": 10  }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
